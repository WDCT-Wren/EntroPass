<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="900.0" minWidth="1316.0" stylesheets="@../Stylesheets/VaultStyleSheet.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.VaultController">
   <left>
      <HBox BorderPane.alignment="CENTER">
         <VBox alignment="TOP_CENTER" minWidth="270.0" spacing="15.0" styleClass="side-bar">
            <HBox fillHeight="false">
               <padding>
                  <Insets left="22.0" right="10.0" top="10.0"/>
               </padding>
               <ImageView fitHeight="81.0" fitWidth="98.0" pickOnBounds="true" preserveRatio="true">
                  <Image url="@../../Assets/Images/EntroPass_Logo_Transparent.png"/>
               </ImageView>
               <GridPane>
                  <columnConstraints>
                     <ColumnConstraints hgrow="SOMETIMES" maxWidth="151.0" minWidth="10.0" prefWidth="151.0"/>
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                     <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                  </rowConstraints>
                  <padding>
                     <Insets bottom="5.0" left="5.0"/>
                  </padding>
                  <HBox.margin>
                     <Insets top="15.0"/>
                  </HBox.margin>
                  <Label styleClass="green-text" text="EntroPass" textFill="#ccff80">
                     <font>
                        <Font name="Segoe UI Bold" size="25.0"/>
                     </font>
                     <GridPane.margin>
                        <Insets top="5.0"/>
                     </GridPane.margin>
                  </Label>
                  <Label styleClass="white-text" text="DIGITAL GREENHOUSE" textFill="#e4e4e4"
                         GridPane.rowIndex="1">
                     <font>
                        <Font name="Segoe UI Bold" size="12.0"/>
                     </font>
                  </Label>
               </GridPane>
            </HBox>
            <Button alignment="TOP_LEFT" mnemonicParsing="false" onAction="#switchToMenuScene"
                    prefHeight="25.0" prefWidth="240.0" styleClass="side-bar-button" text="🏠 Home">
               <font>
                  <Font name="Segoe UI Semibold" size="18.0"/>
               </font>
               <VBox.margin>
                  <Insets/>
               </VBox.margin>
            </Button>
            <Button alignment="TOP_LEFT" mnemonicParsing="false" prefWidth="240.0"
                    styleClass="side-bar-button-selected" stylesheets="@../Stylesheets/VaultStyleSheet.css"
                    text="🔒 Vault">
               <font>
                  <Font name="Segoe UI Semibold" size="18.0"/>
               </font>
            </Button>
            <Button alignment="TOP_LEFT" mnemonicParsing="false" onAction="#switchToPasswordBuilder"
                    prefWidth="240.0" styleClass="side-bar-button" stylesheets="@../Stylesheets/VaultStyleSheet.css"
                    text="🔑 Generator">
               <font>
                  <Font name="Segoe UI Semibold" size="18.0"/>
               </font>
            </Button>
         </VBox>
         <VBox maxWidth="380.0" spacing="20.0" styleClass="list-container"
               stylesheets="@../Stylesheets/VaultStyleSheet.css">
            <GridPane alignment="CENTER_RIGHT" VBox.vgrow="NEVER">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                  <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
               </rowConstraints>
               <VBox.margin>
                  <Insets bottom="20.0"/>
               </VBox.margin>
               <Label fx:id="itemAmountLabel" alignment="CENTER_RIGHT" contentDisplay="RIGHT"
                      styleClass="white-text" text="0" textAlignment="RIGHT" textFill="#868686"
                      GridPane.columnIndex="1" GridPane.halignment="RIGHT" GridPane.valignment="CENTER">
                  <font>
                     <Font name="Segoe UI Bold" size="15.0"/>
                  </font>
               </Label>
               <Label styleClass="white-text" text="Services" textFill="#868686" GridPane.halignment="LEFT"
                      GridPane.valignment="CENTER">
                  <font>
                     <Font name="Segoe UI Bold" size="21.0"/>
                  </font>
               </Label>
            </GridPane>
            <HBox alignment="CENTER">
               <styleClass>
                  <String fx:value="root-textfield"/>
                  <String fx:value="container"/>
               </styleClass>
               <TextField fx:id="searchField" styleClass="root-textfield">
                  <font>
                     <Font name="Segoe UI Semibold" size="16.0"/>
                  </font>
               </TextField>
               <Button mnemonicParsing="false" onAction="#clearSearch" styleClass="main-button" text="❌">
                  <font>
                     <Font name="Segoe UI Emoji" size="10.0"/>
                  </font>
               </Button>
            </HBox>
            <ListView fx:id="userRepoList"
                      style="-fx-cell-vertical-margin: 10.0; -fx-vertical-gap: 10; -fx-background-insets: 0;"
                      VBox.vgrow="ALWAYS"/>
         </VBox>
      </HBox>
   </left>
   <center>
      <HBox BorderPane.alignment="CENTER">
         <StackPane HBox.hgrow="ALWAYS">
            <VBox fx:id="emptyContainer" alignment="CENTER">
               <Label alignment="CENTER" prefHeight="45.0" prefWidth="267.0" styleClass="grey-text"
                      text="No entries yet... so go make one 😉" textAlignment="CENTER" wrapText="true">
                  <font>
                     <Font name="Segoe UI Emoji" size="18.0"/>
                  </font>
               </Label>
            </VBox>
            <VBox fx:id="detailContainer" maxWidth="Infinity" styleClass="root-credential-container" visible="false"
                  StackPane.alignment="CENTER">
               <GridPane VBox.vgrow="NEVER">
                  <columnConstraints>
                     <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                     <ColumnConstraints fillWidth="false" halignment="CENTER" hgrow="SOMETIMES"
                                        maxWidth="1.7976931348623157E308"/>
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints fillHeight="false" vgrow="SOMETIMES"/>
                     <RowConstraints vgrow="SOMETIMES"/>
                  </rowConstraints>
                  <VBox.margin>
                     <Insets/>
                  </VBox.margin>
                  <TextField fx:id="serviceName" alignment="TOP_LEFT" editable="false"
                             styleClass="service-name" text="[Service Name]">
                     <font>
                        <Font name="Segoe UI Black" size="39.0"/>
                     </font>
                     <GridPane.margin>
                        <Insets left="-30.0"/>
                     </GridPane.margin>
                  </TextField>
                  <HBox GridPane.rowIndex="1">
                     <Label text="⏲ Last Updated:" textFill="#868686">
                        <font>
                           <Font name="Segoe UI Bold" size="15.0"/>
                        </font>
                     </Label>
                     <Label fx:id="createdDate" text="[time last updated]" textFill="#868686">
                        <font>
                           <Font name="Segoe UI Bold" size="15.0"/>
                        </font>
                        <HBox.margin>
                           <Insets left="10.0"/>
                        </HBox.margin>
                     </Label>
                  </HBox>
                  <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"
                        GridPane.vgrow="ALWAYS">
                     <Button mnemonicParsing="false"
                             onAction="#deleteConfirmation" text="🗑">
                        <font>
                           <Font name="Segoe UI Emoji" size="15.0"/>
                        </font>
                        <styleClass>
                           <String fx:value="main-button"/>
                           <String fx:value="delete-button"/>
                        </styleClass>
                     </Button>
                     <Button fx:id="editEntryButton" mnemonicParsing="false" onAction="#toggleEditEntry"
                             prefHeight="35.0" prefWidth="69.0" styleClass="main-button" text="✏ Edit">
                        <font>
                           <Font name="Segoe UI Emoji" size="12.0"/>
                        </font>
                     </Button>
                  </HBox>
               </GridPane>
               <VBox alignment="CENTER_LEFT" maxHeight="490.0" spacing="15.0" styleClass="credential-container"
                     VBox.vgrow="ALWAYS">
                  <Label styleClass="green-text" text="USERNAME / EMAIL">
                     <font>
                        <Font name="Segoe UI Black" size="15.0"/>
                     </font>
                  </Label>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <styleClass>
                        <String fx:value="root-textfield"/>
                        <String fx:value="container"/>
                     </styleClass>
                     <TextField fx:id="userName" editable="false" minWidth="520.0" prefHeight="45.0"
                                prefWidth="576.0" styleClass="root-textfield" text="ssdf">
                        <font>
                           <Font name="Segoe UI Semibold" size="16.0"/>
                        </font>
                     </TextField>
                     <Button fx:id="copyUsername" mnemonicParsing="false" onAction="#copyUsername"
                             styleClass="main-button" text="📋">
                        <font>
                           <Font name="Segoe UI Emoji" size="12.0"/>
                        </font>
                     </Button>
                  </HBox>
                  <Label styleClass="green-text" text="PASSWORD">
                     <font>
                        <Font name="Segoe UI Black" size="15.0"/>
                     </font>
                  </Label>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="5.0">
                     <styleClass>
                        <String fx:value="root-textfield"/>
                        <String fx:value="container"/>
                     </styleClass>
                     <StackPane>
                        <TextField fx:id="viewablePassword" editable="false" prefWidth="514.0"
                                   styleClass="root-textfield" visible="false"/>
                        <PasswordField fx:id="password" editable="false" minWidth="475.0"
                                       prefHeight="45.0" prefWidth="514.0" styleClass="root-textfield"
                                       text="sdfsdf" StackPane.alignment="CENTER_LEFT">
                           <font>
                              <Font name="Segoe UI Semibold" size="16.0"/>
                           </font>
                           <StackPane.margin>
                              <Insets/>
                           </StackPane.margin>
                        </PasswordField>
                     </StackPane>
                     <Button fx:id="viewPassword" alignment="CENTER" contentDisplay="RIGHT"
                             mnemonicParsing="false" onAction="#toggleView" styleClass="main-button"
                             text="👁" textAlignment="RIGHT">
                        <font>
                           <Font name="Segoe UI Emoji" size="12.0"/>
                        </font>
                     </Button>
                     <Button fx:id="copyPassword" alignment="CENTER" contentDisplay="RIGHT"
                             mnemonicParsing="false" onAction="#copyPassword" styleClass="main-button"
                             text="📋" textAlignment="RIGHT">
                        <font>
                           <Font name="Segoe UI Emoji" size="12.0"/>
                        </font>
                        <HBox.margin>
                           <Insets right="5.0"/>
                        </HBox.margin>
                     </Button>
                  </HBox>
                  <VBox fx:id="strengthContainer" spacing="5.0" VBox.vgrow="ALWAYS">
                     <VBox.margin>
                        <Insets top="-15.0"/>
                     </VBox.margin>
                     <HBox prefHeight="10.0" prefWidth="541.0" spacing="10.0" VBox.vgrow="ALWAYS">
                        <padding>
                           <Insets top="5.0"/>
                        </padding>
                        <Label styleClass="green-text" text="New Password Strength:">
                           <font>
                              <Font name="Segoe UI Semibold" size="15.0"/>
                           </font>
                        </Label>
                        <Label fx:id="passwordStrength" styleClass="green-text">
                           <font>
                              <Font name="Segoe UI Semibold" size="15.0"/>
                           </font>
                        </Label>
                     </HBox>
                     <ProgressBar fx:id="strengthIndicator" minHeight="5.0" minWidth="560.0"
                                  styleClass="strength-indicator">
                        <VBox.margin>
                           <Insets/>
                        </VBox.margin>
                     </ProgressBar>
                  </VBox>
                  <Label styleClass="green-text" text="NOTES">
                     <font>
                        <Font name="Segoe UI Black" size="15.0"/>
                     </font>
                  </Label>
                  <TextArea fx:id="notes" editable="false" prefHeight="220.0" prefWidth="551.0"
                            promptText="notes go here" styleClass="notes-area">
                     <VBox.margin>
                        <Insets top="-5.0"/>
                     </VBox.margin>
                     <font>
                        <Font name="Segoe UI Semibold Italic" size="15.0"/>
                     </font>
                  </TextArea>
                  <HBox fx:id="buttonContainer" alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0"
                        spacing="10.0">
                     <Button mnemonicParsing="false" onAction="#saveEditsConfirmation"
                             prefHeight="25.0" prefWidth="90.0" styleClass="edit-buttons" text="Save Edits">
                        <font>
                           <Font name="Segoe UI Emoji" size="12.0"/>
                        </font>
                     </Button>
                     <Button mnemonicParsing="false" onAction="#cancelEdits"
                             prefHeight="25.0" prefWidth="90.0" styleClass="edit-buttons" text="Cancel">
                        <font>
                           <Font name="Segoe UI Emoji" size="12.0"/>
                        </font>
                     </Button>
                  </HBox>
               </VBox>
               <Label alignment="BOTTOM_CENTER" contentDisplay="BOTTOM"
                      text="Local Offline Vault    •     Secured via AES-256-GCM &amp; PBKDF2"
                      textAlignment="CENTER" textFill="#868686">
                  <font>
                     <Font name="Segoe UI Semibold" size="15.0"/>
                  </font>
               </Label>
            </VBox>
         </StackPane>
      </HBox>
   </center>
</BorderPane>
