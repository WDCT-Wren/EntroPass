<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="700.0" spacing="16.0" styleClass="Main-Pane" stylesheets="@../Stylesheets/StartingMenuStyleSheet.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.ThirdPartyLicensesController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <javafx.scene.control.Label text="Third-Party Licenses" textFill="#a3e635">
            <font>
                <Font name="Segoe UI Bold" size="22.0" />
            </font>
        </javafx.scene.control.Label>

        <TabPane fx:id="licenseTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="jBCrypt">
                    <content>
                        <TextArea fx:id="jbcryptTextArea" editable="false" wrapText="true" />
                    </content>
                </Tab>
                <Tab text="Apache 2.0 (Passay, sqlite-jdbc)">
                    <content>
                        <TextArea fx:id="apacheTextArea" editable="false" wrapText="true" />
                    </content>
                </Tab>
                <Tab text="JavaFX (GPLv2 + Classpath Exception)">
                    <content>
                        <TextArea fx:id="javafxTextArea" editable="false" wrapText="true" />
                    </content>
                </Tab>
            </tabs>
        </TabPane>

        <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" styleClass="about-button" text="Close" />
    </children>
</VBox>