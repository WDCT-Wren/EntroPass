                  <Label text="EntroPass" textFill="#a3e635">
                     <font>
                        <Font name="Segoe UI Bold" size="53.0" />
                     </font>
                  </Label>
               </children>
            </TextFlow>

            <!-- About -->
            <Label maxWidth="900.0" text="EntroPass is a local-first password manager built with JavaFX. It stores vault entries in an encrypted SQLite database, secured by a master password using PBKDF2-HMAC-SHA256 key derivation and AES-256-GCM authenticated encryption. No data ever leaves your device." textAlignment="CENTER" textFill="#c9c9c9" wrapText="true">
               <font>
                  <Font name="Segoe UI Semibold" size="15.0" />
               </font>
            </Label>

            <Separator prefWidth="900.0" styleClass="about-separator" />

            <!-- Privacy -->
            <Label text="Privacy" textFill="#a3e635">
               <font>
                  <Font name="Segoe UI Bold" size="24.0" />
               </font>
            </Label>
            <Label maxWidth="900.0" text="EntroPass collects no data and makes no network connections. Your vault, master password hash, and salt are stored only in a local SQLite database at ~/EntroPass/PasswordDatabase.sqlite. Nothing is transmitted, logged remotely, or shared with the developer or any third party." textAlignment="CENTER" textFill="#c9c9c9" wrapText="true">
               <font>
                  <Font name="Segoe UI Semibold" size="15.0" />
               </font>
            </Label>

            <Separator prefWidth="900.0" styleClass="about-separator" />

            <!-- Security Disclaimer -->
            <Label text="Security Disclaimer" textFill="#a3e635">
               <font>
                  <Font name="Segoe UI Bold" size="24.0" />
               </font>
            </Label>
            <Label maxWidth="900.0" text="EntroPass has not undergone formal security auditing. While it uses industry-standard cryptographic primitives (AES-256-GCM, PBKDF2-HMAC-SHA256, BCrypt), it is provided as-is, without warranty of any kind, and the developer assumes no liability for data loss or compromise resulting from its use." textAlignment="CENTER" textFill="#c9c9c9" wrapText="true">
               <font>
                  <Font name="Segoe UI Semibold" size="15.0" />
               </font>
            </Label>
            <Label maxWidth="900.0" text="If you forget your master password, your vault cannot be recovered. There is no backdoor, recovery key, or reset mechanism by design. The only option is to delete the database and start over, losing all stored entries. Back up your master password separately and treat it as irreplaceable." textAlignment="CENTER" textFill="#e81313" wrapText="true">
               <font>
                  <Font name="Segoe UI Bold" size="15.0" />
               </font>
            </Label>
            <Label alignment="CENTER" maxWidth="900.0" text="For sensitive, high-value credentials, consider an independently audited password manager." textFill="#c9c9c9" wrapText="true">
               <font>
                  <Font name="Segoe UI Semibold" size="15.0" />
               </font>
            </Label>

            <Separator prefWidth="900.0" styleClass="about-separator" />

            <!-- Third-Party Notices -->
            <Label text="Third-Party Notices" textFill="#a3e635">
               <font>
                  <Font name="Segoe UI Bold" size="24.0" />
               </font>
            </Label>
            <Label maxWidth="900.0" text="EntroPass uses the following open-source libraries: jBCrypt (ISC License), Passay (Apache License 2.0), sqlite-jdbc (Apache License 2.0), and JavaFX (GPL v2 with Classpath Exception). Full license texts for each are included in the application's installation directory." textAlignment="CENTER" textFill="#c9c9c9" wrapText="true">
