<ScrollPane fitToWidth="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1316.0" styleClass="about-scroll" stylesheets="@../Stylesheets/StartingMenuStyleSheet.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.AboutController">
   <content>
      <VBox alignment="TOP_CENTER" spacing="28.0" styleClass="Main-Pane">
         <padding>
            <Insets bottom="60.0" left="80.0" right="80.0" top="40.0" />
         </padding>
         <children>

            <!-- Title -->
            <TextFlow textAlignment="CENTER">
               <children>
                  <ImageView fitHeight="66.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../Assets/Images/EntroPass_Logo_Transparent.png" />
